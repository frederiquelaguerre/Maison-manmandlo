{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Serveur statique (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "Serveur statique Python",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Tailwind CSS Watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tailwindcss", "-i", "./style.css", "-o", "./style.built.css", "--watch"],
      "port": 0
    }
  ]
}
